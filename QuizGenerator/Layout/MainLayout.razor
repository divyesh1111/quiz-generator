@inherits LayoutComponentBase

<div class="min-h-screen bg-slate-50 flex flex-col">
    <!-- Navigation -->
    <NavMenu />

    <!-- Main Content -->
    <main class="flex-1">
        @Body
    </main>

    <!-- Footer -->
    <footer class="bg-slate-800 text-slate-400 py-8 mt-auto">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                <div class="flex items-center gap-2">
                    <span class="text-2xl">🧠</span>
                    <span class="font-bold text-white">Quiz Master Pro</span>
                </div>
                <div class="text-sm text-center md:text-right">
                    <p>Built with .NET Blazor & Tailwind CSS</p>
                    <p class="mt-1">CSCI 6809 — Fairleigh Dickinson University © 2026</p>
                </div>
            </div>
        </div>
    </footer>
</div>