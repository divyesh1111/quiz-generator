@page "/results"
@inject IQuizService QuizService
@inject NavigationManager NavigationManager

<PageTitle>Quiz Master Pro - Results</PageTitle>

@if (_result == null)
{
    <div class="flex items-center justify-center min-h-[70vh]">
        <div class="text-center animate-fade-in">
            <div class="text-6xl animate-bounce-gentle mb-4">🏆</div>
            <p class="text-slate-500">Calculating results...</p>
        </div>
    </div>
}
else
{
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        <!-- Confetti for high scores -->
        @if (_result.Percentage >= 80)
        {
            <div class="fixed inset-0 pointer-events-none z-40 overflow-hidden">
                <div class="absolute text-4xl animate-bounce" style="top: 5%; left: 10%; animation-delay: 0s; animation-duration: 3s;">🎉</div>
                <div class="absolute text-3xl animate-bounce" style="top: 10%; left: 30%; animation-delay: 0.5s; animation-duration: 2.5s;">⭐</div>
                <div class="absolute text-4xl animate-bounce" style="top: 3%; left: 50%; animation-delay: 1s; animation-duration: 3.5s;">🎊</div>
                <div class="absolute text-3xl animate-bounce" style="top: 8%; left: 70%; animation-delay: 0.3s; animation-duration: 2.8s;">✨</div>
                <div class="absolute text-4xl animate-bounce" style="top: 5%; left: 85%; animation-delay: 0.7s; animation-duration: 3.2s;">🌟</div>
            </div>
        }

        <!-- Score Hero Section -->
        <div class="bg-white rounded-2xl shadow-lg p-8 text-center mb-8 animate-scale-in overflow-hidden relative">
            
            <!-- Background Gradient Decoration -->
            <div class="absolute inset-0 bg-gradient-to-br @GetResultGradient() opacity-5"></div>

            <div class="relative z-10">
                <!-- Celebration Emoji -->
                <div class="text-7xl mb-6 animate-bounce-gentle">
                    @GetResultEmoji()
                </div>

                <!-- Score Circle -->
                <div class="relative inline-flex items-center justify-center mb-6">
                    <div class="w-44 h-44 rounded-full bg-gradient-to-br @GetResultGradient() p-1.5 shadow-xl">
                        <div class="w-full h-full rounded-full bg-white flex items-center justify-center">
                            <div>
                                <div class="text-5xl font-black bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-purple-600">
                                    @_result.CorrectAnswers/@_result.TotalQuestions
                                </div>
                                <div class="text-sm text-slate-400 font-medium mt-1">Score</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Percentage -->
                <div class="mb-4">
                    <span class="text-6xl font-black bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-purple-600">
                        @_result.Percentage%
                    </span>
                </div>

                <!-- Grade Badge -->
                <div class="inline-flex items-center gap-2 px-6 py-2 rounded-full text-sm font-bold @GetGradeBadgeClass() mb-6 shadow-sm">
                    🏅 Grade: @_result.Grade
                </div>

                <!-- Performance Message -->
                <p class="text-xl text-slate-600 font-medium max-w-md mx-auto">
                    @_result.PerformanceMessage
                </p>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <!-- Correct -->
            <div class="bg-white rounded-2xl shadow-lg p-5 text-center animate-slide-up" style="animation-delay: 0.1s;">
                <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center mx-auto mb-3">
                    <span class="text-2xl">✅</span>
                </div>
                <div class="text-3xl font-bold text-emerald-600">@_result.CorrectAnswers</div>
                <div class="text-xs text-slate-400 mt-1 font-medium">Correct</div>
            </div>

            <!-- Wrong -->
            <div class="bg-white rounded-2xl shadow-lg p-5 text-center animate-slide-up" style="animation-delay: 0.15s;">
                <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center mx-auto mb-3">
                    <span class="text-2xl">❌</span>
                </div>
                <div class="text-3xl font-bold text-red-500">@_result.WrongAnswers</div>
                <div class="text-xs text-slate-400 mt-1 font-medium">Wrong</div>
            </div>

            <!-- Time -->
            <div class="bg-white rounded-2xl shadow-lg p-5 text-center animate-slide-up" style="animation-delay: 0.2s;">
                <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center mx-auto mb-3">
                    <span class="text-2xl">⏱️</span>
                </div>
                <div class="text-2xl font-bold text-amber-600">@FormatTimeTaken()</div>
                <div class="text-xs text-slate-400 mt-1 font-medium">Time Taken</div>
            </div>

            <!-- Grade -->
            <div class="bg-white rounded-2xl shadow-lg p-5 text-center animate-slide-up" style="animation-delay: 0.25s;">
                <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center mx-auto mb-3">
                    <span class="text-2xl">🏅</span>
                </div>
                <div class="text-3xl font-bold text-indigo-600">@_result.Grade</div>
                <div class="text-xs text-slate-400 mt-1 font-medium">Grade</div>
            </div>
        </div>

        <!-- Performance Bar -->
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-8 animate-slide-up" style="animation-delay: 0.3s;">
            <h3 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
                <span>📊</span> Performance Overview
            </h3>
            <div class="flex items-center gap-4">
                <div class="flex-1 bg-slate-200 rounded-full h-7 overflow-hidden">
                    <div class="h-full rounded-full transition-all duration-1000 ease-out flex items-center justify-end pr-3
                                @GetPerformanceBarColor()"
                         style="width: @(Math.Max(_result.Percentage, 5))%">
                        @if (_result.Percentage > 15)
                        {
                            <span class="text-xs font-bold text-white">@_result.Percentage%</span>
                        }
                    </div>
                </div>
                <span class="text-sm font-bold text-slate-600 w-14 text-right">@_result.Percentage%</span>
            </div>

            <!-- Score Breakdown Bar -->
            <div class="flex gap-1 mt-4 h-2 rounded-full overflow-hidden">
                @if (_result.CorrectAnswers > 0)
                {
                    <div class="bg-emerald-500 rounded-full" 
                         style="width: @((_result.CorrectAnswers * 100.0 / _result.TotalQuestions))%"></div>
                }
                @if (_result.WrongAnswers > 0)
                {
                    <div class="bg-red-400 rounded-full" 
                         style="width: @((_result.WrongAnswers * 100.0 / _result.TotalQuestions))%"></div>
                }
            </div>
            <div class="flex justify-between mt-2 text-xs text-slate-400">
                <span>🟢 @_result.CorrectAnswers Correct</span>
                <span>🔴 @_result.WrongAnswers Wrong</span>
            </div>
        </div>

        <!-- Detailed Review Section -->
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-8 animate-slide-up" style="animation-delay: 0.4s;">
            <button @onclick="ToggleReview"
                    class="w-full flex items-center justify-between text-left py-1">
                <div class="flex items-center gap-3">
                    <span class="text-xl">📋</span>
                    <h3 class="font-bold text-slate-800 text-lg">Detailed Review</h3>
                    <span class="text-xs bg-slate-100 text-slate-500 px-2 py-1 rounded-full">
                        @_result.TotalQuestions questions
                    </span>
                </div>
                <span class="text-2xl text-slate-400 transition-transform duration-300 @(_showReview ? "rotate-180" : "")">
                    ▼
                </span>
            </button>

            @if (_showReview)
            {
                <div class="mt-6 space-y-4 animate-slide-up">
                    @for (int i = 0; i < _result.QuestionResults.Count; i++)
                    {
                        var qr = _result.QuestionResults[i];
                        var qNum = i + 1;

                        <div class="p-5 rounded-xl border-2 transition-all duration-300
                                    @(qr.IsCorrect ? "border-emerald-200 bg-emerald-50/50" : "border-red-200 bg-red-50/50")">
                            
                            <!-- Question Header -->
                            <div class="flex items-start gap-3 mb-3">
                                <div class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 text-sm font-bold
                                            @(qr.IsCorrect ? "bg-emerald-500 text-white" : "bg-red-500 text-white")">
                                    @(qr.IsCorrect ? "✓" : "✕")
                                </div>
                                <div class="flex-1">
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <span class="text-xs font-semibold text-slate-400">Q@qNum</span>
                                        <span class="text-xs px-2 py-0.5 rounded-full @GetDifficultyBadgeClassForReview(qr.Question.DifficultyLevel)">
                                            @qr.Question.DifficultyLevel
                                        </span>
                                        <span class="text-xs text-slate-400">@qr.Question.Category</span>
                                    </div>
                                    <p class="font-semibold text-slate-800 mt-1 text-sm sm:text-base">
                                        @qr.Question.QuestionText
                                    </p>
                                </div>
                            </div>

                            <!-- Answer Details -->
                            <div class="ml-12 space-y-2">
                                @if (qr.SelectedAnswerIndex == -1)
                                {
                                    <div class="text-sm text-slate-400 italic flex items-center gap-2">
                                        <span>⏭️</span> Not answered (time ran out)
                                    </div>
                                }
                                else if (!qr.IsCorrect)
                                {
                                    <div class="flex items-center gap-2 text-sm bg-red-100 rounded-lg px-3 py-2">
                                        <span class="text-red-500">❌</span>
                                        <span class="text-red-700">
                                            Your answer: <strong>@qr.Question.Options[qr.SelectedAnswerIndex]</strong>
                                        </span>
                                    </div>
                                }

                                <div class="flex items-center gap-2 text-sm bg-emerald-100 rounded-lg px-3 py-2">
                                    <span class="text-emerald-500">✅</span>
                                    <span class="text-emerald-700">
                                        Correct answer: <strong>@qr.Question.Options[qr.Question.CorrectAnswerIndex]</strong>
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 animate-slide-up" style="animation-delay: 0.5s;">
            <button @onclick="TryAgain" 
                    class="bg-indigo-600 text-white px-6 py-4 rounded-xl font-semibold 
                           hover:bg-indigo-700 transition-all duration-200 
                           transform hover:scale-105 active:scale-95
                           shadow-lg hover:shadow-xl flex-1 text-center flex items-center justify-center gap-2">
                🔄 Try Again
            </button>
            <button @onclick="ChangeCategory" 
                    class="bg-white text-indigo-600 px-6 py-4 rounded-xl font-semibold 
                           border-2 border-indigo-600
                           hover:bg-indigo-50 transition-all duration-200 
                           transform hover:scale-105 active:scale-95
                           shadow-md hover:shadow-lg flex-1 text-center flex items-center justify-center gap-2">
                📚 Change Category
            </button>
            <button @onclick="GoHome" 
                    class="bg-white text-slate-600 px-6 py-4 rounded-xl font-semibold 
                           border-2 border-slate-300
                           hover:bg-slate-50 transition-all duration-200 
                           transform hover:scale-105 active:scale-95
                           shadow-md hover:shadow-lg flex-1 text-center flex items-center justify-center gap-2">
                🏠 Go Home
            </button>
        </div>
    </div>
}

@code {
    private QuizResult? _result;
    private bool _showReview = false;

    protected override void OnInitialized()
    {
        var session = QuizService.GetCurrentSession();
        if (session == null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        if (!session.IsCompleted)
        {
            QuizService.EndQuiz();
        }

        _result = QuizService.GetResults();
    }

    private void ToggleReview()
    {
        _showReview = !_showReview;
    }

    private void TryAgain()
    {
        NavigationManager.NavigateTo("/categories");
    }

    private void ChangeCategory()
    {
        NavigationManager.NavigateTo("/categories");
    }

    private void GoHome()
    {
        NavigationManager.NavigateTo("/");
    }

    private string FormatTimeTaken()
    {
        if (_result == null) return "00:00";
        var ts = _result.TimeTaken;
        if (ts.TotalMinutes >= 1)
            return $"{(int)ts.TotalMinutes}m {ts.Seconds}s";
        return $"{ts.Seconds}s";
    }

    private string GetResultEmoji()
    {
        if (_result == null) return "🎯";
        return _result.Percentage switch
        {
            >= 90 => "🏆",
            >= 80 => "🌟",
            >= 70 => "🎉",
            >= 60 => "👏",
            >= 50 => "👍",
            _ => "📚"
        };
    }

    private string GetResultGradient()
    {
        if (_result == null) return "from-slate-400 to-slate-500";
        return _result.Percentage switch
        {
            >= 80 => "from-emerald-400 to-teal-500",
            >= 60 => "from-amber-400 to-orange-500",
            _ => "from-red-400 to-pink-500"
        };
    }

    private string GetGradeBadgeClass()
    {
        if (_result == null) return "bg-slate-100 text-slate-700";
        return _result.Percentage switch
        {
            >= 90 => "bg-emerald-100 text-emerald-700",
            >= 80 => "bg-teal-100 text-teal-700",
            >= 70 => "bg-blue-100 text-blue-700",
            >= 60 => "bg-amber-100 text-amber-700",
            >= 50 => "bg-orange-100 text-orange-700",
            _ => "bg-red-100 text-red-700"
        };
    }

    private string GetPerformanceBarColor()
    {
        if (_result == null) return "bg-slate-400";
        return _result.Percentage switch
        {
            >= 80 => "bg-gradient-to-r from-emerald-500 to-teal-500",
            >= 60 => "bg-gradient-to-r from-amber-500 to-orange-500",
            _ => "bg-gradient-to-r from-red-500 to-pink-500"
        };
    }

    private string GetDifficultyBadgeClassForReview(Difficulty difficulty)
    {
        return difficulty switch
        {
            Difficulty.Easy => "bg-emerald-100 text-emerald-700",
            Difficulty.Medium => "bg-amber-100 text-amber-700",
            Difficulty.Hard => "bg-red-100 text-red-700",
            _ => "bg-slate-100 text-slate-700"
        };
    }
}