@page "/quiz"
@inject IQuizService QuizService
@inject NavigationManager NavigationManager
@implements IDisposable

<PageTitle>Quiz Master Pro - Quiz In Progress</PageTitle>

@if (_isLoading)
{
    <!-- Loading State -->
    <div class="flex items-center justify-center min-h-[70vh]">
        <div class="text-center animate-fade-in">
            <div class="text-6xl animate-bounce-gentle mb-6">🧠</div>
            <h2 class="text-2xl font-bold text-slate-800 mb-2">Preparing Your Quiz...</h2>
            <p class="text-slate-500">Get ready to test your knowledge!</p>
        </div>
    </div>
}
else if (_currentQuestion != null)
{
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

        <!-- Top Info Bar -->
        <div class="card mb-6 animate-fade-in">
            <div class="flex flex-wrap items-center justify-between gap-4">
                <!-- Question Counter -->
                <div class="flex items-center gap-2">
                    <span class="text-lg">📝</span>
                    <span class="font-bold text-slate-800">
                        Question @(_session!.CurrentQuestionIndex + 1)
                        <span class="text-slate-400 font-normal">of @_session.Questions.Count</span>
                    </span>
                </div>

                <!-- Timer -->
                <div class="flex items-center gap-2 @GetTimerClass()">
                    <span class="text-lg">⏱️</span>
                    <span class="text-xl font-mono font-bold">
                        @FormatTime(QuizService.GetTimeRemaining())
                    </span>
                </div>

                <!-- Score -->
                <div class="flex items-center gap-2">
                    <span class="text-lg">⭐</span>
                    <span class="font-bold text-indigo-600">@_session.Score pts</span>
                </div>
            </div>

            <!-- Progress Bar -->
            <div class="mt-4 w-full bg-slate-200 rounded-full h-3 overflow-hidden">
                <div class="bg-gradient-to-r from-indigo-500 to-purple-500 h-3 rounded-full transition-all duration-500 ease-out"
                     style="width: @(GetProgress())%">
                </div>
            </div>
        </div>

        <!-- Category & Difficulty Badge -->
        <div class="flex gap-2 mb-4 animate-slide-up">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-indigo-100 text-indigo-700">
                @_currentQuestion.Category
            </span>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold @GetDifficultyBadgeClass()">
                @_currentQuestion.DifficultyLevel
            </span>
        </div>

        <!-- Question Card -->
        <div class="card mb-6 animate-scale-in" @key="_currentQuestion.Id">

            <!-- Question Text -->
            <h2 class="text-xl md:text-2xl font-bold text-slate-800 mb-8 leading-relaxed">
                @_currentQuestion.QuestionText
            </h2>

            <!-- Options -->
            <div class="space-y-3">
                @for (int i = 0; i < _currentQuestion.Options.Count; i++)
                {
                    var index = i;
                    var label = _optionLabels[i];

                    <button @onclick="() => SelectAnswer(index)"
                            disabled="@_hasAnswered"
                            class="w-full flex items-center gap-4 p-4 rounded-xl transition-all duration-300 
                                   @GetOptionClass(index) @(!_hasAnswered ? "cursor-pointer" : "cursor-default")">

                        <!-- Option Label (A, B, C, D) -->
                        <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0
                                    @GetOptionLabelClass(index)">
                            @label
                        </div>

                        <!-- Option Text -->
                        <span class="text-left font-medium flex-1">
                            @_currentQuestion.Options[index]
                        </span>

                        <!-- Result Icon -->
                        @if (_hasAnswered)
                        {
                            @if (index == _currentQuestion.CorrectAnswerIndex)
                            {
                                <span class="text-xl flex-shrink-0">✅</span>
                            }
                            else if (index == _selectedAnswer && !_isCorrect)
                            {
                                <span class="text-xl flex-shrink-0">❌</span>
                            }
                        }
                    </button>
                }
            </div>
        </div>

        <!-- Feedback Message -->
        @if (_hasAnswered)
        {
            <div class="@GetFeedbackClass() p-4 rounded-xl mb-6 animate-slide-up flex items-center gap-3">
                <span class="text-2xl">@(_isCorrect ? "🎉" : "💡")</span>
                <div>
                    <p class="font-bold">
                        @(_isCorrect ? "Correct! Great job!" : "Not quite right!")
                    </p>
                    @if (!_isCorrect)
                    {
                        <p class="text-sm mt-1 opacity-80">
                            The correct answer is: <strong>@_currentQuestion.Options[_currentQuestion.CorrectAnswerIndex]</strong>
                        </p>
                    }
                </div>
            </div>
        }

        <!-- Action Buttons -->
        <div class="flex justify-between items-center animate-fade-in">
            <!-- Quit Button -->
            <button @onclick="QuitQuiz"
                    class="px-4 py-2 rounded-xl text-sm font-medium text-slate-500 
                           hover:text-red-500 hover:bg-red-50 transition-all duration-200">
                ✕ Quit Quiz
            </button>

            <!-- Next / Submit Button -->
            @if (_hasAnswered)
            {
                @if (_session!.CurrentQuestionIndex < _session.Questions.Count - 1)
                {
                    <button @onclick="NextQuestion" class="btn-primary flex items-center gap-2">
                        Next Question
                        <span>→</span>
                    </button>
                }
                else
                {
                    <button @onclick="FinishQuiz" class="btn-success flex items-center gap-2">
                        See Results
                        <span>🏆</span>
                    </button>
                }
            }
            else
            {
                <div class="text-sm text-slate-400 italic">Select an answer above</div>
            }
        </div>
    </div>
}

@code {
    private QuizSession? _session;
    private Question? _currentQuestion;
    private bool _isLoading = true;
    private bool _hasAnswered = false;
    private int _selectedAnswer = -1;
    private bool _isCorrect = false;
    private bool _timerRunning = false;
    private CancellationTokenSource _cts = new();

    private readonly string[] _optionLabels = { "A", "B", "C", "D" };

    protected override async Task OnInitializedAsync()
    {
        _session = QuizService.GetCurrentSession();

        if (_session == null || _session.IsCompleted)
        {
            NavigationManager.NavigateTo("/categories");
            return;
        }

        _currentQuestion = QuizService.GetCurrentQuestion();

        // Check if current question was already answered (navigated back)
        if (QuizService.HasAnsweredCurrentQuestion())
        {
            _hasAnswered = true;
            _selectedAnswer = QuizService.GetSelectedAnswerForCurrentQuestion();
            _isCorrect = _selectedAnswer == _currentQuestion?.CorrectAnswerIndex;
        }

        _isLoading = false;

        // Start timer
        _timerRunning = true;
        _ = RunTimerAsync();
    }

    private async Task RunTimerAsync()
    {
        try
        {
            while (_timerRunning && !_cts.Token.IsCancellationRequested)
            {
                await Task.Delay(1000, _cts.Token);

                if (!_timerRunning) break;

                QuizService.DecrementTimer();

                if (QuizService.GetTimeRemaining() <= 0)
                {
                    _timerRunning = false;
                    QuizService.EndQuiz();
                    await InvokeAsync(() =>
                    {
                        NavigationManager.NavigateTo("/results");
                    });
                    break;
                }

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Timer was cancelled, ignore
        }
        catch (Exception)
        {
            // Handle any other exceptions gracefully
        }
    }

    private void SelectAnswer(int index)
    {
        if (_hasAnswered) return;

        _selectedAnswer = index;
        _hasAnswered = true;
        _isCorrect = QuizService.SubmitAnswer(index);
    }

    private void NextQuestion()
    {
        if (QuizService.NextQuestion())
        {
            _currentQuestion = QuizService.GetCurrentQuestion();
            _hasAnswered = false;
            _selectedAnswer = -1;
            _isCorrect = false;
        }
    }

    private void FinishQuiz()
    {
        _timerRunning = false;
        QuizService.EndQuiz();
        NavigationManager.NavigateTo("/results");
    }

    private void QuitQuiz()
    {
        _timerRunning = false;
        QuizService.EndQuiz();
        NavigationManager.NavigateTo("/");
    }

    private string FormatTime(int totalSeconds)
    {
        int minutes = totalSeconds / 60;
        int seconds = totalSeconds % 60;
        return $"{minutes:D2}:{seconds:D2}";
    }

    private double GetProgress()
    {
        if (_session == null) return 0;
        return ((_session.CurrentQuestionIndex + 1) * 100.0) / _session.Questions.Count;
    }

    private string GetTimerClass()
    {
        var remaining = QuizService.GetTimeRemaining();
        if (remaining <= 30) return "text-red-500 animate-pulse";
        if (remaining <= 60) return "text-amber-500";
        return "text-slate-700";
    }

    private string GetDifficultyBadgeClass()
    {
        return _currentQuestion?.DifficultyLevel switch
        {
            Difficulty.Easy => "bg-emerald-100 text-emerald-700",
            Difficulty.Medium => "bg-amber-100 text-amber-700",
            Difficulty.Hard => "bg-red-100 text-red-700",
            _ => "bg-slate-100 text-slate-700"
        };
    }

    private string GetOptionClass(int index)
    {
        if (!_hasAnswered)
        {
            return "bg-white border-2 border-slate-200 hover:border-indigo-400 hover:bg-indigo-50 hover:shadow-md";
        }

        if (index == _currentQuestion?.CorrectAnswerIndex)
        {
            return "bg-emerald-50 border-2 border-emerald-400 shadow-md";
        }

        if (index == _selectedAnswer && !_isCorrect)
        {
            return "bg-red-50 border-2 border-red-400 shadow-md";
        }

        return "bg-slate-50 border-2 border-slate-200 opacity-50";
    }

    private string GetOptionLabelClass(int index)
    {
        if (!_hasAnswered)
        {
            return "bg-slate-100 text-slate-600 group-hover:bg-indigo-100 group-hover:text-indigo-600";
        }

        if (index == _currentQuestion?.CorrectAnswerIndex)
        {
            return "bg-emerald-500 text-white";
        }

        if (index == _selectedAnswer && !_isCorrect)
        {
            return "bg-red-500 text-white";
        }

        return "bg-slate-100 text-slate-400";
    }

    private string GetFeedbackClass()
    {
        return _isCorrect
            ? "bg-emerald-50 border border-emerald-200 text-emerald-800"
            : "bg-red-50 border border-red-200 text-red-800";
    }

    public void Dispose()
    {
        _timerRunning = false;
        _cts.Cancel();
        _cts.Dispose();
    }
}