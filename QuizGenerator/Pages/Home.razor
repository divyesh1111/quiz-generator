@page "/"
@inject IQuestionBankService QuestionBank
@inject IQuizService QuizService
@inject NavigationManager NavigationManager

<PageTitle>Quiz Master Pro - Home</PageTitle>

<!-- Hero Section -->
<section class="relative overflow-hidden bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-500 text-white">
    <!-- Decorative circles -->
    <div class="absolute top-10 left-10 w-72 h-72 bg-white/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-pink-400/10 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 w-64 h-64 bg-indigo-400/10 rounded-full blur-3xl"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32">
        <div class="text-center animate-fade-in">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 mb-8">
                <span class="animate-pulse-slow">🔥</span>
                <span class="text-sm font-medium">@QuestionBank.GetTotalQuestionCount()+ Questions Available</span>
            </div>

            <!-- Title -->
            <h1 class="text-5xl md:text-7xl font-black mb-6 leading-tight">
                Challenge Your
                <br />
                <span class="relative">
                    Knowledge
                    <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 300 12" fill="none">
                        <path d="M2 10C50 2 100 2 150 6C200 10 250 4 298 8" stroke="rgba(255,255,255,0.4)" stroke-width="3" stroke-linecap="round"/>
                    </svg>
                </span>
            </h1>

            <!-- Subtitle -->
            <p class="text-xl md:text-2xl text-white/80 mb-10 max-w-2xl mx-auto leading-relaxed">
                Test yourself with quizzes across multiple categories.
                Track your score, beat the timer, and become a Quiz Master!
            </p>

            <!-- CTA Buttons -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <button @onclick="QuickStart"
                        class="bg-white text-indigo-600 px-8 py-4 rounded-xl font-bold text-lg
                               hover:bg-indigo-50 active:bg-indigo-100
                               transition-all duration-200 transform hover:scale-105 active:scale-95
                               shadow-2xl hover:shadow-white/25 w-full sm:w-auto">
                    ⚡ Quick Start
                </button>
                <a href="/categories"
                   class="bg-white/20 backdrop-blur-sm text-white border-2 border-white/40 
                          px-8 py-4 rounded-xl font-bold text-lg
                          hover:bg-white/30 transition-all duration-200 
                          transform hover:scale-105 active:scale-95
                          shadow-xl w-full sm:w-auto text-center">
                    🎯 Choose Category
                </a>
            </div>
        </div>
    </div>

    <!-- Wave Divider -->
    <div class="absolute bottom-0 left-0 right-0">
        <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 120L60 105C120 90 240 60 360 52.5C480 45 600 60 720 67.5C840 75 960 75 1080 67.5C1200 60 1320 45 1380 37.5L1440 30V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="#f8fafc"/>
        </svg>
    </div>
</section>

<!-- Stats Section -->
<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Stat Card 1 -->
        <div class="card-hover text-center animate-slide-up" style="animation-delay: 0.1s;">
            <div class="text-4xl mb-3">📝</div>
            <div class="text-3xl font-bold text-indigo-600">@QuestionBank.GetTotalQuestionCount()+</div>
            <div class="text-slate-500 font-medium mt-1">Quiz Questions</div>
        </div>

        <!-- Stat Card 2 -->
        <div class="card-hover text-center animate-slide-up" style="animation-delay: 0.2s;">
            <div class="text-4xl mb-3">📚</div>
            <div class="text-3xl font-bold text-purple-600">@QuestionBank.GetCategoryCount()</div>
            <div class="text-slate-500 font-medium mt-1">Categories</div>
        </div>

        <!-- Stat Card 3 -->
        <div class="card-hover text-center animate-slide-up" style="animation-delay: 0.3s;">
            <div class="text-4xl mb-3">⏱️</div>
            <div class="text-3xl font-bold text-pink-600">Timed</div>
            <div class="text-slate-500 font-medium mt-1">Challenges</div>
        </div>
    </div>
</section>

<!-- How It Works Section -->
<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-800 mb-4">How It Works</h2>
        <p class="text-lg text-slate-500">Three simple steps to test your knowledge</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Step 1 -->
        <div class="text-center group">
            <div class="w-20 h-20 bg-indigo-100 rounded-2xl flex items-center justify-center mx-auto mb-6 
                        group-hover:bg-indigo-600 transition-colors duration-300">
                <span class="text-3xl group-hover:scale-125 transition-transform duration-300">🎯</span>
            </div>
            <div class="bg-indigo-600 text-white text-xs font-bold rounded-full w-6 h-6 flex items-center justify-center mx-auto mb-4">1</div>
            <h3 class="text-xl font-bold text-slate-800 mb-2">Choose Your Quiz</h3>
            <p class="text-slate-500">Select a category, difficulty level, and number of questions</p>
        </div>

        <!-- Step 2 -->
        <div class="text-center group">
            <div class="w-20 h-20 bg-purple-100 rounded-2xl flex items-center justify-center mx-auto mb-6 
                        group-hover:bg-purple-600 transition-colors duration-300">
                <span class="text-3xl group-hover:scale-125 transition-transform duration-300">✍️</span>
            </div>
            <div class="bg-purple-600 text-white text-xs font-bold rounded-full w-6 h-6 flex items-center justify-center mx-auto mb-4">2</div>
            <h3 class="text-xl font-bold text-slate-800 mb-2">Answer Questions</h3>
            <p class="text-slate-500">Race against the timer and answer each question carefully</p>
        </div>

        <!-- Step 3 -->
        <div class="text-center group">
            <div class="w-20 h-20 bg-pink-100 rounded-2xl flex items-center justify-center mx-auto mb-6 
                        group-hover:bg-pink-600 transition-colors duration-300">
                <span class="text-3xl group-hover:scale-125 transition-transform duration-300">🏆</span>
            </div>
            <div class="bg-pink-600 text-white text-xs font-bold rounded-full w-6 h-6 flex items-center justify-center mx-auto mb-4">3</div>
            <h3 class="text-xl font-bold text-slate-800 mb-2">See Your Results</h3>
            <p class="text-slate-500">Get detailed feedback, review answers, and track your performance</p>
        </div>
    </div>
</section>

<!-- Categories Preview Section -->
<section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-slate-800 mb-4">Quiz Categories</h2>
            <p class="text-lg text-slate-500">Explore our diverse collection of quiz topics</p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
            @foreach (var cat in _categoryData)
            {
                <div class="card-hover text-center cursor-pointer group" @onclick='() => StartCategoryQuiz(cat.Name)'>
                    <div class="text-4xl mb-3 group-hover:scale-125 transition-transform duration-300">@cat.Icon</div>
                    <h3 class="font-bold text-slate-800 text-sm">@cat.Name</h3>
                    <p class="text-xs text-slate-400 mt-1">@cat.Count questions</p>
                </div>
            }
        </div>

        <div class="text-center mt-10">
            <a href="/categories" class="btn-primary inline-block">
                Explore All Categories →
            </a>
        </div>
    </div>
</section>

@code {
    private List<CategoryInfo> _categoryData = new();

    protected override void OnInitialized()
    {
        var categories = QuestionBank.GetCategories();
        var iconMap = new Dictionary<string, string>
        {
            { "General Knowledge", "🧠" },
            { "Science", "🔬" },
            { "Mathematics", "📐" },
            { "History", "📜" },
            { "Geography", "🌍" }
        };

        foreach (var cat in categories)
        {
            _categoryData.Add(new CategoryInfo
            {
                Name = cat,
                Icon = iconMap.ContainsKey(cat) ? iconMap[cat] : "📝",
                Count = QuestionBank.GetQuestionsByCategory(cat).Count
            });
        }
    }

    private void QuickStart()
    {
        QuizService.StartNewQuiz(10, 600, null, null);
        NavigationManager.NavigateTo("/quiz");
    }

    private void StartCategoryQuiz(string category)
    {
        QuizService.StartNewQuiz(10, 600, category, null);
        NavigationManager.NavigateTo("/quiz");
    }

    private class CategoryInfo
    {
        public string Name { get; set; } = "";
        public string Icon { get; set; } = "";
        public int Count { get; set; }
    }
}